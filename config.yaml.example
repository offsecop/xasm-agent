agent:
  name: "Agent-001"
  description: "Default ASM Platform Agent"
  tags:
    - internal
    - scanner
  
server:
  api_url: "http://localhost:3001/api"
  # Per-instance enrollment (no static api_key): each instance enrolls via
  # POST /agents/enroll/tenant with the tenant's client credentials + its own
  # installationUid, and receives its own per-instance key at boot.
  client_id: "your-tenant-agent-client-id"
  client_secret: "your-tenant-agent-client-secret"
  # AGENT_INSTALLATION_UID env (optional): a stable per-container id; otherwise
  # the agent derives one (K_REVISION + uuid) so each instance gets its own row.

tools:
  - name: "system:dns_resolve"
    enabled: true
  - name: "nmap:host_discovery"
    enabled: true
  - name: "nmap:port_scan_all"
    enabled: true
  - name: "nmap:service_scan"
    enabled: true

heartbeat_interval: 30  # seconds
poll_interval: 5  # seconds

# Note: Make sure Nmap is installed on the agent host
# Ubuntu/Debian: sudo apt-get install nmap
# macOS: brew install nmap
# Windows: Download from https://nmap.org/download.html
